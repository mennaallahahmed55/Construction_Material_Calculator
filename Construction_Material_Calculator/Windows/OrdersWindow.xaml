<Window x:Class="Construction_Material_Calculator.Windows.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orders Manager"
        Height="600"
        Width="950"
        Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
            <TextBlock Text="Orders Manager" FontSize="18" FontWeight="Bold" Foreground="#212529" Margin="20"/>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
            <StackPanel Margin="20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Width="60"/>
                    <TextBox x:Name="SearchTextBox"
                             Width="150"
                             Margin="0,0,20,0"
                             Padding="8"
                             Background="White"
                             BorderBrush="#E9ECEF"
                             TextChanged="SearchTextBox_TextChanged"/>

                    <TextBlock Text="Category:" VerticalAlignment="Center" Width="70"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Width="120"
                              Padding="8"
                              Background="White"
                              BorderBrush="#E9ECEF"
                              ItemsSource="{Binding CategoryOrdersCombox}"
                              SelectionChanged="CategoryComboBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" VerticalAlignment="Center" Width="60"/>
                    <ComboBox x:Name="StatusComboBox"
                              Width="120"
                              Padding="8"
                              Margin="0,0,20,0"
                              SelectedIndex="0"
                              Background="White"
                              BorderBrush="#E9ECEF"
                              SelectionChanged="StatusComboBox_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Delivered"/>
                    </ComboBox>

                    <TextBlock Text="From:" VerticalAlignment="Center" Width="50"/>
                    <DatePicker x:Name="FromDatePicker"
                                Width="120"
                                Margin="0,0,10,0"
                                Padding="8"
                                Background="White"
                                BorderBrush="#E9ECEF"
                                SelectedDateChanged="FromDatePicker_SelectedDateChanged"/>

                    <TextBlock Text="To:" VerticalAlignment="Center" Width="30"/>
                    <DatePicker x:Name="ToDatePicker"
                                Width="120"
                                Padding="8"
                                Background="White"
                                BorderBrush="#E9ECEF"
                                SelectedDateChanged="ToDatePicker_SelectedDateChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="OrdersDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  ItemsSource="{Binding OrdersGrid}"
                  Margin="20,20,20,20"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#F8F9FA"
                  BorderBrush="#E9ECEF"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E9ECEF">

            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding OrderNumber}"
                                    Width="50"/>
                <DataGridTextColumn Header="Material"
                                    Binding="{Binding MaterialName}"
                                    Width="*"/>
                <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}"
                                    Width="80"/>
                <DataGridTextColumn Header="Price"
                                    Binding="{Binding UnitPrice, StringFormat=N2}"
                                    Width="100"/>
                <DataGridTextColumn Header="Total"
                                    Binding="{Binding Total, StringFormat=N2}"
                                    Width="100"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <Grid Margin="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Orders: " FontWeight="Bold"/>
                    <TextBlock x:Name="OrdersCountTextBlock" Text="0" Margin="0,0,20,0"/>
                    <TextBlock Text="Total: EGP " FontWeight="Bold"/>
                    <TextBlock x:Name="TotalAmountTextBlock" Text="0.00" Margin="0,0,20,0"/>
                    <TextBlock Text="Pending: " FontWeight="Bold"/>
                    <TextBlock x:Name="PendingCountTextBlock" Text="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MarkDeliveredButton"
                            Content="Mark Delivered"
                            Style="{StaticResource MenuButtonStyle}"
                            Background="#28A745"
                            Foreground="White"
                            Margin="0,0,10,0"
                            Click="MarkDeliveredButton_Click"/>
                    <Button x:Name="DeleteButton"
                            Content="Delete"
                            Style="{StaticResource MenuButtonStyle}"
                            Background="#DC3545"
                            Foreground="White"
                            Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>