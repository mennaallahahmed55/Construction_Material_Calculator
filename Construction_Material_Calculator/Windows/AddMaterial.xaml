<Window x:Class="Construction_Material_Calculator.Windows.AddMaterial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Material"
        Height="480"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>
    </Window.Effect>

    <Border CornerRadius="10"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Grid Grid.Row="0" Margin="20,0">

                <TextBlock Text="Add Material"
                           Style="{StaticResource HeaderTextBlock}"
                           VerticalAlignment="Center"/>

                <Button Content="✕"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Button_Cancel"/>

            </Grid>

            <!-- CONTENT -->

            <ScrollViewer Grid.Row="1"
                          Padding="25,10"
                          VerticalScrollBarVisibility="Hidden">

                <StackPanel>

                    <StackPanel Margin="0,10">

                        <TextBlock Text="Material Category"
                                   Style="{StaticResource LabelTextBlock}"/>

                        <ComboBox x:Name="CategoryBox"
                                  ItemsSource="{Binding MaterialType}"
                                  SelectedIndex="0"/>

                    </StackPanel>

                    <StackPanel Margin="0,15">

                        <TextBlock Text="Material Name"
                                   Style="{StaticResource LabelTextBlock}"/>

                        <TextBox x:Name="MaterialNameTxt"
                                 TextChanged="TextBox_TextChanged"/>

                        <TextBlock x:Name="NameErrorMsg"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushDanger}"/>
                    </StackPanel>

                    <Grid Margin="0,10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">

                            <TextBlock Text="Unit Price (EGP)"
                                       Style="{StaticResource LabelTextBlock}"/>

                            <TextBox x:Name="UnitPriceTxt"
                                     TextChanged="TextBox_TextChanged"/>

                            <TextBlock x:Name="UnitPriceMsg"
                                       FontSize="10"
                                       Foreground="{StaticResource BrushDanger}"/>

                        </StackPanel>

                        <StackPanel Grid.Column="1">

                            <TextBlock Text="Unit"
                                       Style="{StaticResource LabelTextBlock}"/>

                            <TextBox x:Name="UnitTxt"
                                     TextChanged="TextBox_TextChanged"/>

                            <TextBlock x:Name="UnitErrorMsg"
                                       FontSize="10"
                                       Foreground="{StaticResource BrushDanger}"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>

            </ScrollViewer>

            <!-- FOOTER -->

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="25">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="18*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource SecondaryBtn}"
                            Height="38"
                            Margin="-6,-44,16,25"
                            Click="Button_Cancel"/>

                    <Button
                            x:Name="BtnSave"
                            Content="Add Material"
                            Style="{StaticResource PrimaryBtn}"
                            Height="38"
                            FontWeight="SemiBold"
                            Click="Button_Save"
                            IsEnabled="False" Grid.ColumnSpan="3" Margin="183,-44,1,25"/>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>